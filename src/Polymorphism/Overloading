Case 4:
class Test {
    public void m1(int i) {
        System.out.println("general");
    }
    public void m1(int ... i) { // "..." operator can take 0-infinity variables (introduced in Java 1.5)
        System.out.println("variable args");
    }
    public static void main(String[] args) {
        Test t = new Test();
        t.m1();// variable args
        t.m1(10, 20, 30);// variable args
        t.m1(10);// general
         variable arg methods have the least priority
    }
}


