        System.out.println("Animal");
    }
    public void m1(Dog d) {
        System.out.println("Dog");
    }
    public static void main (String[] args) {
        Test t = new Test();
        Animal a = new Animal();
        t.m1(a);// Animal
        Dog d = new Dog();
        t.m1(d);// Dog
        Animal n = new Dog();
        t.m1(n);// Animal

    }
}
Parent class Reference can hold child class object
