Case 2:
class Test {
    public void m1(Object o) {
        System.out.println("Object");
    }
    public void m1(String s) {
        System.out.println("string");
    }

    public static void  main(String[] args) {
        Test t = new Test();
        t.m1(new Object()); //Object
        t.m1("Hello"); //String
 In overloading child argument will get highest priority than parent argument
 Exactly matched method will get highest priority
        t.m1(null); //String
    }
}


